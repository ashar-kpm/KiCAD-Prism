# --- KiCAD Prism Root Environment Variables ---
# Use this file as a template for your own .env file at the project root.
# These variables are consumed by docker-compose and passed into backend/frontend.

# ===========================================
# Authentication (OIDC/OAuth2 + RBAC)
# ===========================================
# Friendly workspace display name shown on the login page
WORKSPACE_NAME=KiCAD Prism

# Set to false to disable authentication entirely (guest viewer mode)
AUTH_ENABLED=true

# Required when AUTH_ENABLED=true and DEV_MODE=false.
# For Google Sign-In, use:
#   OIDC_ISSUER_URL=https://accounts.google.com
#   OIDC_SCOPES=openid email profile
#   OIDC_EMAIL_CLAIM=email
#   OIDC_NAME_CLAIM=name
#   OIDC_PICTURE_CLAIM=picture
#   OIDC_PROVIDER_NAME=Google
#   OIDC_TOKEN_AUTH_METHOD=client_secret_post
# Other OIDC providers usually use the same claim names, but check their
# discovery/userinfo docs if email, name, or picture are mapped differently.
# If your provider requires HTTP Basic authentication at the token endpoint,
# set OIDC_TOKEN_AUTH_METHOD=client_secret_basic.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid email profile
OIDC_EMAIL_CLAIM=email
OIDC_NAME_CLAIM=name
OIDC_PICTURE_CLAIM=picture
OIDC_PROVIDER_NAME=SSO
OIDC_TOKEN_AUTH_METHOD=client_secret_post

# Optional allowlist filters (leave empty to rely only on RBAC role assignments)
ALLOWED_USERS_STR=
ALLOWED_DOMAINS_STR=

# Bootstrap admins (comma-separated SSO account emails)
BOOTSTRAP_ADMIN_USERS_STR=admin@example.com

# Domains that receive implicit viewer access when no explicit RBAC role is set
# Leave empty to require explicit RBAC assignments for non-admin users.
# Example: DEFAULT_VIEWER_DOMAINS_STR=example.com,engineering.example.com
DEFAULT_VIEWER_DOMAINS_STR=

# Path override for role store file (optional)
# Defaults to <KICAD_PROJECTS_ROOT>/.rbac_roles.json
ROLE_STORE_PATH=

# Required: session signing secret for HttpOnly auth cookie
SESSION_SECRET=

# Session lifetime in hours
SESSION_TTL_HOURS=12

# Set true only behind HTTPS
SESSION_COOKIE_SECURE=false

# Browser origins allowed to make credentialed API calls.
# Keep this explicit; do not use "*" with session cookies.
CORS_ORIGINS_STR=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080,http://localhost:8080

# Local OAuth2 service-client tokens for PLM/MRP integrations
OAUTH_SERVICE_TOKEN_TTL_SECONDS=3600

# Optional external OAuth2/OIDC bearer JWT validation for machine clients
OAUTH_EXTERNAL_JWT_ISSUER_URL=
OAUTH_EXTERNAL_JWT_AUDIENCE=
OAUTH_EXTERNAL_JWT_ROLE_CLAIM=prism_role
OAUTH_EXTERNAL_JWT_SCOPES_CLAIM=scope
OAUTH_EXTERNAL_JWT_CLIENT_ID_CLAIM=client_id

# ===========================================
# KiCad Remote Symbol Provider
# ===========================================
# SQLite is the default catalog database for remote symbols, KiCad OAuth state,
# and local OAuth2 service-client metadata. Leave blank to use:
#   data/projects/.kicad-prism/prism.sqlite3
CATALOG_SQLITE_PATH=

# Generated CERN-style KiCad DBL bundle output. Leave blank to use:
#   data/projects/.kicad-prism/exports/kicad-dbl
CATALOG_DBL_EXPORT_DIR=

# Local startup defaults. For an office/VPN workstation deployment, use 4-6
# workers on an 8-core host; SQLite WAL handles concurrent read traffic well.
UVICORN_WORKERS=4
GIT_SCAN_KNOWN_HOSTS_ON_STARTUP=false

# Public OAuth client id advertised to KiCad
REMOTE_PROVIDER_OAUTH_CLIENT_ID=kicad-prism-kicad

# Access token lifetime for KiCad provider auth
REMOTE_PROVIDER_ACCESS_TOKEN_TTL_SECONDS=3600

# Refresh token lifetime for KiCad provider auth
REMOTE_PROVIDER_REFRESH_TOKEN_TTL_SECONDS=604800

# Must match KiCad's Remote Symbols destination settings if you customize them
REMOTE_PROVIDER_LIBRARY_PREFIX=remote
# Use $${KIPRJMOD} in Compose env files so Docker does not interpolate it away.
REMOTE_PROVIDER_DESTINATION_DIR=$${KIPRJMOD}/RemoteLibrary

# ===========================================
# Manufacturo Sync
# ===========================================
# SQL Server connection used by the Library Manager "Sync Manufacturo" action
MANUFACTURO_SQL_SERVER=
MANUFACTURO_SQL_DATABASE=
MANUFACTURO_SQL_USERNAME=
MANUFACTURO_SQL_PASSWORD=
MANUFACTURO_SQL_DRIVER=ODBC Driver 18 for SQL Server

# Optional development cap on imported rows
MANUFACTURO_SYNC_LIMIT=0

# ===========================================
# Git & Repository Access
# ===========================================
# Optional: GitHub PAT for private repository import/sync
GITHUB_TOKEN=

# ===========================================
# Runtime / Development
# ===========================================
# Keep false for normal auth behavior
DEV_MODE=false
